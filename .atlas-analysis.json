  "keyFeatures": [
    "REST API with versioning (v6–v10) for full Discord platform access",
    "Gateway WebSocket API for real-time events and presence",
    "Application Commands (slash commands, context menus) and interactive Components",
    "Discord Social SDK for integrating voice, friends, rich presence into games",
    "Activities — embedded multiplayer games and experiences inside Discord",
    "OAuth2 and bot token authentication with granular permissions",
    "Monetization support: subscriptions, one-time purchases, SKUs, entitlements",
    "Webhook-based event delivery as an alternative to the Gateway",
    "Rich Presence for displaying game status in Discord profiles",
    "Auto-moderation, audit logs, and community server management APIs"
  ],
  "publicApiSurface": [
    "GET/POST/PATCH/DELETE /channels/{channel.id}",
    "GET/POST /channels/{channel.id}/messages",
    "GET/POST/PATCH/DELETE /guilds/{guild.id}",
    "GET/PATCH /users/@me",
    "POST /interactions/{interaction.id}/{interaction.token}/callback",
    "GET/POST /applications/{application.id}/commands",
    "GET /gateway/bot",
    "GET /oauth2/authorize",
    "GET/POST /applications/{application.id}/entitlements",
    "GET/POST /guilds/{guild.id}/auto-moderation/rules",
    "GET/POST /webhooks/{webhook.id}/{webhook.token}",
    "GET /guilds/{guild.id}/audit-logs"
  ]
